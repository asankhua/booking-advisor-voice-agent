# ============================================
# PHASE 1: VOICE PIPELINE (Local Models - Whisper + ParlerTTS)
# ============================================
# Using local models instead of Sarvam API:
# - Whisper (OpenAI) for Speech-to-Text
# - ParlerTTS (HuggingFace) for Text-to-Speech
# - Silero VAD for Voice Activity Detection

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ============================================
# VOICE PROVIDER TOGGLE
# ============================================
# sarvam = Sarvam AI — Saaras v3 STT + Bulbul v2 TTS
#          Faster (~500ms), Indian accent, cloud API
#          Requires SARVAM_API_KEY
# local  = HuggingFace — Whisper Base STT + ParlerTTS Mini TTS
#          Offline, no API key, slower (~5s on CPU)
# Default: sarvam
# ============================================
VOICE_PROVIDER=sarvam
SARVAM_API_KEY=your_sarvam_api_key_here
# Get your free key at: https://console.sarvam.ai

# ============================================
# PHASE 2: MCP TOOLS - PRODUCTION CONFIG
# ============================================

# --- MCP SERVER CONFIGURATION ---
# Local development: localhost:8000 (runs on your machine)
# Production: Change to your domain or cloud server IP (AWS EC2, GCP, etc.)
# This server hosts ALL MCP tools: Calendar, Notes (Google Docs), Email
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8000

# --- CALENDAR (Google Calendar API via MCP) ---
# This is an MCP tool endpoint: POST /calendar/event
# Requires Google OAuth credentials below
CALENDAR_PROVIDER=google
GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com

# Google OAuth Credentials (Option 1: Environment Variables - Recommended for production)
# Get these from your google-credentials.json file or Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost

# Google OAuth Credentials (Option 2: JSON File - For local development)
# GOOGLE_CREDENTIALS_PATH=config/google-credentials.json
GOOGLE_TOKEN_PATH=config/google-token.json

# --- NOTES (Google Docs via MCP) ---
# This is an MCP tool endpoint: POST /notes/append
# Doc URL will be provided after setup
NOTES_PROVIDER=googledocs
GOOGLE_DOC_ID=your-google-doc-id-here

# --- EMAIL (Resend API via MCP) ---
# Sign up at https://resend.com/ → Create API Key
# Free tier: 3,000 emails/month
EMAIL_PROVIDER=resend
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME="Advisor Booking System"

# ============================================
# PHASE 3: LLM ORCHESTRATOR
# ============================================
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0.3

# State Management
MAX_CONVERSATION_TURNS=20
CONTEXT_EXPIRY_MINUTES=30

# ============================================
# PHASE 4: Compliance & Performance
# ============================================
# PII Detection (optional - for enhanced filtering)
PII_DETECTION_ENABLED=true

# Latency Targets
MAX_LATENCY_MS=3000
ENABLE_LATENCY_WARNINGS=true

# ============================================
# OPTIONAL: Logging
# ============================================
LOG_LEVEL=INFO
ENABLE_LATENCY_LOGS=true
